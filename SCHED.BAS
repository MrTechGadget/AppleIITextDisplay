10  REM ==========================================
20  REM KANSASFEST AUTO-REFRESHING SCHEDULE VIEWER
30  REM REQUIRES APPLE II + FUJINET + BASIC EXT
40  REM ==========================================
50  TEXT : HOME : CLEAR
60  U = 0 : M = 12 : T = 0
70  LASTHASH = -1
80  REFRESH_SEC = 300 : REM 5 MINUTES (300 SECONDS)
90  URL$ = "N:HTTPS://RAW.GITHUBUSERCONTENT.COM/MRTECHGADGET/APPLEIITEXTDISPLAY/MAIN/2026.TXT"
100 ;
110 REM --- MAIN CONTROL LOOP ---
120 VTAB 24 : HTAB 1 : PRINT "CHECKING FOR UPDATES..."; : CALL -868
130 GOSUB 300 : REM COMPUTE CURRENT FILE HASH
140 ;
150 IF NEWHASH = LASTHASH THEN GOTO 200 : REM NO CHANGE DETECTED
160 ;
170 REM --- FILE CHANGED: REDRAW SCREEN ---
180 LASTHASH = NEWHASH
190 GOSUB 500 : REM DRAW SCHEDULE TO SCREEN
200 ;
210 REM --- WAIT LOOP (5 MINUTES WITH KEY LISTENER) ---
220 VTAB 24 : HTAB 1
230 PRINT "STATUS: OK | 'R'=REFRESH 'Q'=QUIT"; : CALL -868
240 FOR SEC = 1 TO REFRESH_SEC
250   K = PEEK(-16384) : REM CHECK KEYBOARD BUFFER
260   IF K < 128 THEN GOTO 290
270   POKE -16368, 0   : REM CLEAR KEYSTROKE STROBE
280   IF K = 210 OR K = 242 THEN GOTO 110 : REM 'R' OR 'r' FORCE REFRESH
290   IF K = 209 OR K = 241 THEN END       : REM 'Q' OR 'q' QUIT
300   FOR DELAY = 1 TO 700 : NEXT DELAY   : REM ~1 SECOND DELAY ON 1MHZ
310 NEXT SEC
320 GOTO 110 : REM TIME EXPIRED, CHECK AGAIN
330 ;
340 REM ==========================================
350 REM SUBROUTINE: COMPUTE FILE CHECKSUM
360 REM ==========================================
370 NEWHASH = 0
380 & NOPEN U, M, T, URL$
390 & NSTATUS U, STAT, BYTES
400 IF STAT > 127 THEN GOTO 470 : REM CONNECTION ERROR
410 IF BYTES = 0 AND STAT = 0 THEN GOTO 470 : REM EOF
420 IF BYTES = 0 THEN GOTO 390
430 & NREAD U, BUF$, 128
440 FOR I = 1 TO LEN(BUF$)
450   NEWHASH = NEWHASH + ASC(MID$(BUF$, I, 1))
460 NEXT I
470 GOTO 390
480 & NCLOSE U
490 RETURN
500 ;
510 REM ==========================================
520 REM SUBROUTINE: STREAM & DISPLAY SCHEDULE
530 REM ==========================================
540 HOME
550 & NOPEN U, M, T, URL$
560 & NSTATUS U, STAT, BYTES
570 IF BYTES = 0 AND STAT = 0 THEN GOTO 630
580 IF BYTES = 0 THEN GOTO 560
590 & NREAD U, BUF$, 128
600 PRINT BUF$;
610 GOTO 560
620 & NCLOSE U
630 RETURN
